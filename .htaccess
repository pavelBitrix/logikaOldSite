Options -Indexes
ErrorDocument 404 /404.php

# --- CORS для /api/* ---
<IfModule mod_headers.c>
  <If "%{REQUEST_URI} =~ m|^/api|">
    SetEnvIf Origin "^(https://logika1c\.ru|https://www\.logika1c\.ru|http://localhost(:\d+)?|http://127\.0\.0\.1(:\d+)?|http://0\.0\.0\.0(:\d+)?)$" CORS_ORIGIN=$0
    Header always set Access-Control-Allow-Origin "%{CORS_ORIGIN}e" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, PATCH, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-HTTP-Method-Override"
    Header always set Access-Control-Allow-Credentials "true"
  </If>
</IfModule>

<IfModule mod_php.c>
  php_flag session.use_trans_sid off
  php_flag mail.add_x_header off
  php_flag allow_url_fopen off
  php_value opcache.revalidate_freq 0
  php_value max_input_vars 10000
  php_value max_execution_time 300
  php_value pcre.recursion_limit 1000
  php_flag display_errors off
  php_value error_log "/home/l/logika1cma/error_log"
  php_value error_reporting 7
  php_value request_order "GP"
</IfModule>

<IfModule mod_rewrite.c>
  Options +FollowSymLinks
  RewriteEngine On
  RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

  # --- CORS preflight на уровне Apache (до PHP) ---
  RewriteCond %{REQUEST_METHOD} OPTIONS
  RewriteCond %{REQUEST_URI} ^/api(/|$)
  RewriteRule ^ - [R=204,L]

  # --- Logika API ---
  RewriteRule ^local/ - [F,L]
  RewriteRule ^1c-exchange/? /local/php_interface/1c_exchange.php [L,QSA]
  RewriteCond %{REQUEST_URI} ^/api(/|$)
  RewriteRule ^api/(.*)$ /api.php [L,QSA]
  # --- /Logika API ---
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !/bitrix/urlrewrite.php$
  RewriteRule ^(.*)$ /bitrix/urlrewrite.php [L]
  RewriteRule .* - [E=REMOTE_USER:%{HTTP:Authorization}]
  RewriteCond %{HTTP_USER_AGENT} SemrushBot
  RewriteRule (.*) - [F,L]
</IfModule>

<IfModule mod_dir.c>
  DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_headers.c>
  Header set Strict-Transport-Security "max-age=31536000;"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive on
  ExpiresByType image/jpeg "access plus 3 day"
  ExpiresByType image/gif "access plus 3 day"
  ExpiresByType image/png "access plus 3 day"
  ExpiresByType text/css "access plus 3 day"
  ExpiresByType application/javascript "access plus 3 day"  
  
  
</IfModule>